# cloudflare-uptime — environment configuration reference
# This file documents every value you need to supply before deploying.
# Most values are set as Wrangler secrets or in wrangler.toml, not in a
# traditional .env file — see the notes next to each entry.

# ── Cloudflare account ──────────────────────────────────────────────────────

# Your Cloudflare API token (needs Workers:Edit + D1:Edit + R2:Edit permissions).
# Used by the GitHub Actions deploy workflow (stored as a GitHub Actions secret).
# To create: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# ── Wrangler secrets (set via: wrangler secret put <NAME>) ──────────────────

# API key used to authenticate all admin API calls and the admin dashboard.
# Generate a strong random string, e.g.: openssl rand -hex 32
API_KEY=change-me-to-a-random-secret-string

# ── wrangler.toml values (edit the file directly) ───────────────────────────

# D1 database ID produced by: wrangler d1 create uptime-monitor
# Paste the output ID into the database_id field in wrangler.toml.
D1_DATABASE_ID=YOUR_D1_DATABASE_ID

# R2 bucket name for logo uploads. Created with: wrangler r2 bucket create uptime-assets
# Set as bucket_name in the [[r2_buckets]] block of wrangler.toml.
R2_BUCKET_NAME=uptime-assets

# ── Optional: custom domains ─────────────────────────────────────────────────

# To serve status pages on your own domain, add a routes block to wrangler.toml:
#   routes = [
#     { pattern = "status.yourdomain.com", custom_domain = true },
#   ]
# Each domain must be proxied through Cloudflare in your DNS settings.
